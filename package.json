{
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "cd server && npm run dev",
    "dev:client": "cd client && npm run dev",
    "install:all": "npm install --prefix server && npm install --prefix client"
  },
  "dependencies": {
    "vite": "^7.3.1"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
